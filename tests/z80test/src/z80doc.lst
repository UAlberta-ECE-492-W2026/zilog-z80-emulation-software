       7:. 00:8966                                  macro   db8 b7,b6,b5,b4,b3,b2,b1,b0
       8:. 00:8966                    <             db      (b7<<7)|(b6<<6)|(b5<<5)|(b4<<4)|(b3<<3)|(b2<<2)|(b1<<1)|b0
       9:. 00:8966                    <             endm
      10:. 00:8966                                  
      11:. 00:8966                                  macro   ddbe n
      12:. 00:8966                    <             db      (n>>24)&0xff
      13:. 00:8966                    <             db      (n>>16)&0xff
      14:. 00:8966                    <             db      (n>>8)&0xff
      15:. 00:8966                    <             db      n&0xff
      16:. 00:8966                    <             endm
      17:. 00:8966                      
      18:. 00:8966                                  macro   inst op1,op2,op3,op4,tail
      19:. 00:8966                    <             ; Unfortunately, elseifidn doesn't seem to work properly.
      20:. 00:8966                    <             ifidn   op4,stop
      21:. 00:8966                    <             db      op1,op2,op3,tail,0
      22:. 00:8966                    <             else
      23:. 00:8966                    <             ifidn   op3,stop
      24:. 00:8966                    <             db      op1,op2,tail,op4,0
      25:. 00:8966                    <             else
      26:. 00:8966                    <             ifidn   op2,stop
      27:. 00:8966                    <             db      op1,tail,op3,op4,0
      28:. 00:8966                    <             else
      29:. 00:8966                    <             db      op1,op2,op3,op4,tail
      30:. 00:8966                    <             endif
      31:. 00:8966                    <             endif
      32:. 00:8966                    <             endif
      33:. 00:8966                    <             endm
      34:. 00:8966                      
      35:. 00:8966                                  macro   flags sn,s,zn,z,f5n,f5,hcn,hc,f3n,f3,pvn,pv,nn,n,cn,c
      36:. 00:8966                    <             if      maskflags
      37:. 00:8966                    <             db8     s,z,f5,hc,f3,pv,n,c
      38:. 00:8966                    <             else
      39:. 00:8966                    <             db      0xff
      40:. 00:8966                    <             endif
      41:. 00:8966                    <             endm
      42:. 00:8966                      
      43:. 00:8966  (00:0000)           .veccount := 0
      44:. 00:8966                      
      45:. 00:8966                                  macro   vec op1,op2,op3,op4,memn,mem,an,a,fn,f,bcn,bc,den,de,hln,hl,ixn,ix,iyn,iy,spn,sp
      46:. 00:8966                    < 
      47:. 00:8966                    <             if      postccf
      48:. 00:8966                    < 
      49:. 00:8966                    <             if      ( .@veccount % 3 ) == 0
      50:. 00:8966                    <             inst    op1,op2,op3,op4,tail
      51:. 00:8966                    < .@areg      :=      0
      52:. 00:8966                    <             else
      53:. 00:8966                    <             db      op1,op2,op3,op4,0
      54:. 00:8966                    < .@areg      :=      .@areg | a
      55:. 00:8966                    <             endif
      56:. 00:8966                    < 
      57:. 00:8966                    <             else
      58:. 00:8966                    <             db      op1,op2,op3,op4
      59:. 00:8966                    <             endif
      60:. 00:8966                    < 
      61:. 00:8966                    <             db      f
      62:. 00:8966                    < 
      63:. 00:8966                    <             if      postccf & ( ( .@veccount % 3 ) == 2 )
      64:. 00:8966                    <             db      a | ( ( ~ .@areg ) & 0x28 )
      65:. 00:8966                    <             else
      66:. 00:8966                    <             db      a
      67:. 00:8966                    <             endif
      68:. 00:8966                    < 
      69:. 00:8966                    <             dw      bc,de,hl,ix,iy
      70:. 00:8966                    <             dw      mem
      71:. 00:8966                    <             dw      sp
      72:. 00:8966                    < 
      73:. 00:8966                    < .@veccount := .@veccount+1
      74:. 00:8966                    < 
      75:. 00:8966                    <             endm
      76:. 00:8966                      
      77:. 00:8966                                  macro   crcs allflagsn,allflags,alln,all,docflagsn,docflags,docn,doc,ccfn,ccf,mptrn,mptr
      78:. 00:8966                    <             if      postccf
      79:. 00:8966                    <             ddbe    ccf
      80:. 00:8966                    <             elseif  memptr
      81:. 00:8966                    <             ddbe    mptr
      82:. 00:8966                    <             else
      83:. 00:8966                    <             if      maskflags
      84:. 00:8966                    <             if      onlyflags
      85:. 00:8966                    <             ddbe    docflags
      86:. 00:8966                    <             else
      87:. 00:8966                    <             ddbe    doc
      88:. 00:8966                    <             endif
      89:. 00:8966                    <             else
      90:. 00:8966                    <             if      onlyflags
      91:. 00:8966                    <             ddbe    allflags
      92:. 00:8966                    <             else
      93:. 00:8966                    <             ddbe    all
      94:. 00:8966                    <             endif
      95:. 00:8966                    <             endif
      96:. 00:8966                    <             endif
      97:. 00:8966                    <             endm
      98:. 00:8966                                  
      99:. 00:8966                                  macro   name n
     100:. 00:8966                    <             dz      n
     101:. 00:8966                    <             endm
