     235:  00:8966                      
     236:  00:8966                                  ; Test vector template.
     237:  00:8966                                  ; 
     238:  00:8966                                  ; Each test consists of the following:
     239:  00:8966                                  ; - Bitmask of which of the modified flags are officially documented.
     240:  00:8966                                  ; - Three test vectors - base test vector, counter vector and shifter vector.
     241:  00:8966                                  ; - The CRCs for each of the available test variants.
     242:  00:8966                                  ; - Test name.
     243:  00:8966                                  ; - Type of test pre-check, if any.
     244:  00:8966                                  ;
     245:  00:8966                                  ; The base test vectors specifies the instruction(s) to execute,
     246:  00:8966                                  ; the initial value of the memory operand, and the initial
     247:  00:8966                                  ; values of the Z80 registers.
     248:  00:8966                                  ;
     249:  00:8966                                  ; The counter vector specifies which combinations of bits shall
     250:  00:8966                                  ; be toggled in the base test vectors. The test vector is
     251:  00:8966                                  ; executed once for each possible combination.
     252:  00:8966                                  ;
     253:  00:8966                                  ; The shifter vector specifies which bits shall be toggled in
     254:  00:8966                                  ; the test vector in sequence. After all the initial counter
     255:  00:8966                                  ; combinations were executed, the whole process is repeated, but
     256:  00:8966                                  ; now also toggling one of the specified shifter bits at a time.
     257:  00:8966                                  ;
     258:  00:8966                                  ; The pre-check byte specifies if the test should be skipped and under what condition.
     259:  00:8966                                  ; Note that it is seldom needed so most often I abuse the flags byte of the following test instead.
     260:  00:8966                      
     261:  00:8966                                  if 0
     262:  00:8966                    ~             flags   s,1,z,1,f5,0,hc,1,f3,0,pv,1,n,1,c,1
     263:  00:8966                    ~             vec     0x00,0x00,0x00,0x00,mem,0x1234,a,0xaa,f,0xff,bc,0xbbcc,de,0xddee,hl,0x4411,ix,0xdd88,iy,0xfd77,sp,0xc000
     264:  00:8966                    ~             vec     0x00,0x00,0x00,0x00,mem,0x0000,a,0x00,f,0x00,bc,0x0000,de,0x0000,hl,0x0000,ix,0x0000,iy,0x0000,sp,0x0000
     265:  00:8966                    ~             vec     0x00,0x00,0x00,0x00,mem,0x0000,a,0x00,f,0x00,bc,0x0000,de,0x0000,hl,0x0000,ix,0x0000,iy,0x0000,sp,0x0000
     266:  00:8966                    ~             crcs    allflags,0xaf0f0011,all,0xac0f0022,docflags,0xdf0f0033,doc,0xdc0f0044,ccf,0x0,mptr,0x0
     267:  00:8966                    ~             name    " "
     268:  00:8966                    ~             endif
     269:  00:8966                      
